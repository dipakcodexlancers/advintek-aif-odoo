<odoo>

    <!-- FORM VIEW -->
    <record id="view_partner_form_lhdn" model="ir.ui.view">
        <field name="name">res.partner.lhdn.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Add after Tax ID -->
            <xpath expr="//field[@name='vat']" position="after">
                <field name="lhdn_tin"/>
                <field name="lhdn_id_type"/>
                <field name="lhdn_id_value"/>
            </xpath>

        </field>
    </record>


    <!-- LIST VIEW -->
    <record id="view_partner_tree_lhdn" model="ir.ui.view">
        <field name="name">res.partner.lhdn.tree</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">

            <!-- Add columns -->
            <xpath expr="//list" position="inside">
                <field name="lhdn_tin" width="120"/>
                <field name="lhdn_id_type" width="180"/>
                <field name="lhdn_id_value" width="120"/>
            </xpath>

        </field>
    </record>

</odoo>