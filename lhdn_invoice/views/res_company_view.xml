<odoo>

    <record id="view_company_form_lhdn" model="ir.ui.view">
        <field name="name">res.company.lhdn.form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">

            <!-- Add directly after Currency -->
            <xpath expr="//field[@name='currency_id']" position="after">

                <field name="lhdn_tin"/>
                <field name="lhdn_id_type"/>
                <field name="lhdn_id_value"/>
                <field name="lhdn_business_activity"/>
                <field name="lhdn_msic_code"/>
                <field name="lhdn_payment_means_code"/>
                <field name="lhdn_payment_terms"/>

            </xpath>

        </field>
    </record>

</odoo>